use axum::Router;
use std::net::SocketAddr;
use utoipa::OpenApi;
use utoipa_swagger_ui::SwaggerUi;
use tracing_subscriber::EnvFilter;

mod app_state;
mod config;
mod shared;
mod modules;
{%- if with_db and not infra_as_shared %}
mod infra;
{%- endif %}

use app_state::AppState;
use config::settings::Settings;

/// OpenAPI documentation aggregator.
///
/// New module paths and schemas are registered here via marker comments.
/// When you run `aksum generate module`, paths are auto-inserted.
#[derive(OpenApi)]
#[openapi(
    paths(
        modules::health::controller::health_check,
        // aksum:openapi_paths
    ),
    components(
        schemas(
            modules::health::schema::HealthResponse,
            // aksum:openapi_schemas
        )
    ),
    info(
        title = "{{ ProjectName }} API",
        version = "0.1.0",
        description = "API documentation for {{ ProjectName }}"
    )
)]
struct ApiDoc;

#[tokio::main]
async fn main() {
    // Initialize tracing subscriber for structured logging
    tracing_subscriber::fmt()
        .with_env_filter(EnvFilter::from_default_env())
        .init();

    // Load environment variables from .env file
    dotenvy::dotenv().ok();
    let settings = Settings::from_env();

    // Build the application state with all dependencies
    let state = AppState::new(
        {%- if with_db %}&settings{% endif -%}
    ).await;

    // Compose the router from all module routes.
    // New modules are auto-wired here by `aksum generate module`.
    let app = Router::new()
        .merge(modules::health::controller::routes())
        // aksum:module_routes
        .merge(
            SwaggerUi::new("/swagger-ui")
                .url("/api-docs/openapi.json", ApiDoc::openapi()),
        )
        .with_state(state);

    // Bind and serve
    let addr = SocketAddr::from(([0, 0, 0, 0], settings.port));
    tracing::info!("🚀 Server listening on {}", addr);
    let listener = tokio::net::TcpListener::bind(addr).await.unwrap();
    axum::serve(listener, app).await.unwrap();
}
